{
  "name": "codexdock",
  "version": "0.2.0",
  "description": "CLI worker that connects host apps to a local Codex runtime.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codexdock": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tahooki/codexdock.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/tahooki/codexdock#readme",
  "bugs": {
    "url": "https://github.com/tahooki/codexdock/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/make-executable.mjs dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "worker": "tsx src/index.ts start"
  },
  "dependencies": {
    "@codexdock/sdk": "workspace:*",
    "@openai/codex-sdk": "^0.140.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
