{
  "name": "@codexdock/sdk",
  "version": "0.1.2",
  "description": "Server-side SDK for routing app AI invocations to local CodexDock workers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tahooki/codexdock.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/tahooki/codexdock#readme",
  "bugs": {
    "url": "https://github.com/tahooki/codexdock/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codexdock/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
