{
  "name": "codexdock-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm -r --sort build",
    "check": "node scripts/check-package-versions.mjs && pnpm --filter @codexdock/sdk build && pnpm -r --sort check",
    "check:versions": "node scripts/check-package-versions.mjs",
    "dev": "pnpm --filter @codexdock/sdk build && pnpm --filter @codexdock/example-web dev",
    "worker": "pnpm --filter @codexdock/sdk build && pnpm --filter codexdock worker",
    "qa:smoke": "pnpm build && node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "next": "^16.0.8",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
